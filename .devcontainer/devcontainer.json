{
  "name": "BAOBAB Development Environment",

  "build": {
    "context": "..",
    "dockerfile": "docker/Dockerfile",
    "target": "development",
    "args": {
      "UBUNTU_VERSION": "26.04",
      "BAOBAB_ENV": "development"
    }
  },

  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "remoteUser": "vscode",

  "overrideCommand": false,

  "updateRemoteUserUID": true,

  "shutdownAction": "stopContainer",

  "runArgs": [
    "--shm-size=2g"
  ],

  "mounts": [
    "source=baobab-pip-cache,target=/home/vscode/.cache/pip,type=volume",
    "source=baobab-uv-cache,target=/home/vscode/.cache/uv,type=volume"
  ],

  "containerEnv": {
    "BAOBAB_ENV": "development",
    "PYTHONUNBUFFERED": "1",
    "PIP_DISABLE_PIP_VERSION_CHECK": "1",
    "UV_LINK_MODE": "copy"
  },

  "postCreateCommand": "bash .devcontainer/docker/scripts/run.sh bootstrap",

  "updateContentCommand": "bash .devcontainer/docker/scripts/run.sh post-create",

  "postStartCommand": "bash .devcontainer/docker/scripts/summary.sh",

  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.formatOnSaveMode": "file",

        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit",
          "source.fixAll": "explicit"
        },

        "editor.rulers": [
          88
        ],

        "editor.renderWhitespace": "selection",

        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "files.eol": "\n",

        "terminal.integrated.defaultProfile.linux": "bash",

        "python.analysis.typeCheckingMode": "basic",

        "git.autofetch": true,

        "docker.showStartPage": false
      },

      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",

        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",

        "dart-code.dart-code",
        "dart-code.flutter",

        "ms-azuretools.vscode-docker",

        "github.vscode-github-actions",

        "editorconfig.editorconfig",

        "eamodio.gitlens"
      ]
    }
  },

  "forwardPorts": [
    3000,
    5432,
    6379,
    8000,
    8001,
    8025
  ],

  "portsAttributes": {
    "3000": {
      "label": "Next.js Frontend",
      "onAutoForward": "notify"
    },

    "5432": {
      "label": "PostgreSQL"
    },

    "6379": {
      "label": "Redis"
    },

    "8000": {
      "label": "Django Backend",
      "onAutoForward": "openBrowser"
    },

    "8001": {
      "label": "FastAPI AI Service",
      "onAutoForward": "notify"
    },

    "8025": {
      "label": "Mailpit"
    }
  }
}
