###############################################################################
# BAOBAB Enterprise Platform
#
# Development Environment
###############################################################################

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------

BAOBAB_ENV=development
BAOBAB_NAME=baobab

# -----------------------------------------------------------------------------
# Workspace
# -----------------------------------------------------------------------------

BAOBAB_HOME=/workspaces/baobab

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

BAOBAB_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Verification
# -----------------------------------------------------------------------------

BAOBAB_VERIFY=true
